# AMRMotionTurn — Arc turn with radius R
# Goal
float64 target_angle          # deg (+ CCW, - CW)
float64 turn_radius           # m (> 0)
float64 max_linear_speed      # m/s (always > 0, max 0.4 for Gazebo DiffDrive)
float64 accel_angle           # deg (accel/decel angular distance, > 0)
---
# Result
int8    status                # 0=success, -1=cancelled, -2=invalid_param, -3=timeout
float64 actual_angle          # deg
float64 elapsed_time          # sec
---
# Feedback
float64 current_angle         # deg (accumulated)
float64 current_linear_speed  # m/s
float64 current_angular_speed # deg/s
float64 remaining_angle       # deg
uint8   phase                 # 1=accel, 2=cruise, 3=decel
float64 w1_drive_rpm          # left wheel RPM (info only)
float64 w2_drive_rpm          # right wheel RPM (info only)
